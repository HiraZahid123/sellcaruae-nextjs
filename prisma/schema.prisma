// SellCarUAE — Prisma Schema (MySQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─── CAR CATALOG ────────────────────────────────────────────────────────────

model Make {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(100)
  slug         String     @unique @db.VarChar(100)
  logoUrl      String?    @map("logo_url") @db.VarChar(500)
  isActive     Boolean    @default(true) @map("is_active")
  displayOrder Int        @default(0) @map("display_order") @db.SmallInt
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  carModels    CarModel[]

  @@index([isActive])
  @@map("makes")
}

model CarModel {
  id        Int       @id @default(autoincrement())
  makeId    Int       @map("make_id")
  name      String    @db.VarChar(100)
  slug      String    @db.VarChar(100)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  make      Make      @relation(fields: [makeId], references: [id])
  variants  Variant[]

  @@unique([makeId, slug])
  @@index([makeId])
  @@index([isActive])
  @@map("car_models")
}

model Variant {
  id           Int      @id @default(autoincrement())
  modelId      Int      @map("model_id")
  year         Int      @db.SmallInt
  name         String   @db.VarChar(200)
  bodyType     String?  @map("body_type") @db.VarChar(50)
  engine       String?  @db.VarChar(100)
  transmission String?  @db.VarChar(50)
  gccSpecs     Boolean  @default(true) @map("gcc_specs")
  isActive     Boolean  @default(true) @map("is_active")
  priceMin     Int?     @map("price_min")
  priceMax     Int?     @map("price_max")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  model        CarModel @relation(fields: [modelId], references: [id])
  leads        Lead[]

  @@index([modelId])
  @@index([year])
  @@index([isActive])
  @@fulltext([name])
  @@map("variants")
}

// ─── LEADS & APPOINTMENTS ───────────────────────────────────────────────────

model Lead {
  id             Int        @id @default(autoincrement())
  variantId      Int?       @map("variant_id")
  make           String     @db.VarChar(100)
  model          String     @db.VarChar(100)
  year           String     @db.VarChar(10)
  modelDetails   String?    @map("model_details") @db.VarChar(200)
  mileage        String?    @db.VarChar(50)
  specifications String?    @db.VarChar(50)
  phoneNumber    String     @map("phone_number") @db.VarChar(20)
  status         LeadStatus @default(NEW_LEAD)
  userIp         String?    @map("user_ip") @db.VarChar(45)
  isVerified     Boolean    @default(false) @map("is_verified")
  yourPrice      String?    @map("your_price") @db.VarChar(50)
  bookingOn      DateTime?  @map("booking_on")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  variant        Variant?      @relation(fields: [variantId], references: [id])
  appointments   Appointment[]

  @@index([status])
  @@index([phoneNumber])
  @@index([userIp])
  @@index([createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW_LEAD
  IN_NEGOTIATION
  VISITED
  PURCHASED
  FAKE_LEAD
  NUMBER_NOT_WORKING
}

model Appointment {
  id          Int             @id @default(autoincrement())
  leadId      Int             @map("lead_id")
  bookingType BookingType     @map("booking_type")
  leadType    AppointmentType @default(MAIN) @map("lead_type")
  branch      String?         @db.VarChar(100)
  homeAddress String?         @map("home_address") @db.VarChar(500)
  date        DateTime
  time        String          @db.VarChar(20)
  email       String          @db.VarChar(200)
  isLatest    Boolean         @default(true) @map("is_latest")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  lead        Lead            @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([date])
  @@index([isLatest])
  @@map("appointments")
}

enum BookingType {
  OFFICE_VISIT
  HOME_INSPECTION
}

enum AppointmentType {
  MAIN
  SECONDARY
}

// ─── USERS & ROLES ──────────────────────────────────────────────────────────

model Role {
  id        Int      @id @default(autoincrement())
  type      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  users     User[]

  @@map("roles")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(200)
  password  String   @db.VarChar(200)
  roleId    Int      @map("role_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  role      Role     @relation(fields: [roleId], references: [id])
  blogs     Blog[]

  @@index([email])
  @@map("users")
}

// ─── BLOG ────────────────────────────────────────────────────────────────────

model Blog {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(191)
  slug        String    @unique @db.VarChar(191)
  content     String    @db.LongText
  thumbnail   String?   @db.VarChar(500)
  authorId    Int?      @map("author_id")
  categories  String?   @db.VarChar(500)
  publishedAt DateTime? @map("published_at")
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author      User?     @relation(fields: [authorId], references: [id])

  @@index([slug])
  @@index([isPublished])
  @@map("blogs")
}
